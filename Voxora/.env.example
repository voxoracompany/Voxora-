# ── Voxora V5.3 — Firebase Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your Firebase project values.
# Never commit .env — it is listed in .gitignore.
#
# Firebase Console → Project Settings → Your apps → Web app → SDK config.
# Create a project at: https://console.firebase.google.com

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Behaviour when variables are NOT set ──────────────────────────────────────
# The app runs normally in "Local Demo Mode" — all data is stored in your
# browser's localStorage.  Nothing is synced to the cloud.
#
# Once you set the variables above and run `npm run dev` (or deploy), the app
# automatically switches to Firebase Auth + Firestore cloud mode.

# ── Firestore Rules (paste into Firebase Console → Firestore → Rules) ─────────
# rules_version = '2';
# service cloud.firestore {
#   match /databases/{database}/documents {
#     match /users/{userId}/{document=**} {
#       allow read, write: if request.auth != null && request.auth.uid == userId;
#     }
#   }
# }

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Only needed for AI features (V5.2).  Get a key at: https://aistudio.google.com
VITE_GEMINI_API_KEY=
